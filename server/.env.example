# Copy to .env and fill in. Generate strong tokens:  openssl rand -hex 32
PORT=8080

# Bearer token the AI / MCP client must send:  Authorization: Bearer <AI_TOKEN>
AI_TOKEN=replace-me-ai

# Shared secret the phone APK presents when it connects to /agent
DEVICE_TOKEN=replace-me-device

# Per-command timeout defaults (ms)
DEFAULT_TIMEOUT_MS=60000
MAX_TIMEOUT_MS=600000
