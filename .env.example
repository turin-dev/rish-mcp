# Compose env for docker-compose.yml (gitignore the real .env)
MCP_HOST=mcp.example.com
AI_TOKEN=generate-with-openssl-rand-hex-32
DEVICE_TOKEN=generate-with-openssl-rand-hex-24
# External https origin for OAuth metadata/redirects (claude.ai connectors).
# docker-compose derives this from MCP_HOST; only set it when running the
# server directly without compose.
# PUBLIC_URL=https://mcp.example.com
